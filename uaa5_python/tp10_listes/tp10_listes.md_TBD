    ```python
        >>> assert moins_6_carac(['Jean', 'Maximilien', 'Brigitte', 'Sonia', 'Jean-Pierre', 'Sandra']) == ['Jean', 'Sonia'], ['Maximilien', 'Brigitte', 'Jean-Pierre', 'Sandra']
